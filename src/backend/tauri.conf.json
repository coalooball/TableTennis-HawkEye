{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TableTennis-HawkEye",
  "version": "0.1.0",
  "identifier": "com.tabletennis.hawkeye",
  "build": {
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TableTennis-HawkEye",
